  "info": {
    "_postman_id": "488fad59-d33f-4f36-abd2-2587ff1843b2",
    "name": "Lunchbox POS API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Lunchbox 2.0 POS API defines the contract between Lunchbox and a POS provider integration. Lunchbox retrieves store details and submits orders to the POS provider, and the POS provider notifies Lunchbox of store and order changes via webhooks. This specification documents the endpoints Lunchbox calls on the POS provider, plus the inbound webhooks the POS provider sends to Lunchbox (modeled as callbacks). All payloads are JSON.\n\nContact Support:\n Name: Lunchbox Support\n Email: support@lunchbox.io",
      "type": "text/plain"
    }
  }
