        {
          "info": {
            "name": "Lunchbox Refund an Order",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://{chain_name}.lunchbox.io/api/v2/management/orders/:order_id/refund",
            "params": [
