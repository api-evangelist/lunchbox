{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UserWalletCreate",
  "description": "UserWalletCreate schema from Lunchbox Loyalty API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/lunchbox/refs/heads/main/json-schema/loyalty-user-wallet-create-schema.json",
  "type": "object",
  "properties": {
    "firstName": {
      "type": "string",
      "example": "John"
    },
    "lastName": {
      "type": "string",
      "example": "Smith"
    },
    "birthdate": {
      "type": "string",
      "format": "date",
      "example": "1990-05-21"
    },
    "email": {
      "type": "string",
      "format": "email",
      "example": "demo@lunchbox.io"
    },
    "phone": {
      "type": "string",
      "example": "2125551411"
    }
  },
  "required": [
    "email"
  ]
}