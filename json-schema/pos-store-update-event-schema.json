{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StoreUpdateEvent",
  "description": "StoreUpdateEvent schema from Lunchbox POS API",
  "$id": "https://raw.githubusercontent.com/api-evangelist/lunchbox/refs/heads/main/json-schema/pos-store-update-event-schema.json",
  "type": "object",
  "properties": {
    "event_type": {
      "type": "string",
      "enum": [
        "store_update"
      ],
      "example": "store_update"
    },
    "pos_store_id": {
      "type": "string",
      "example": "123456"
    }
  },
  "required": [
    "event_type",
    "pos_store_id"
  ]
}