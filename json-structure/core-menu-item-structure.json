{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/lunchbox/refs/heads/main/json-structure/core-menu-item-structure.json",
  "name": "MenuItem",
  "description": "MenuItem schema from Lunchbox Core API",
  "type": "object",
  "properties": {
    "item_id": {
      "type": "int32",
      "example": 1234
    },
    "category_id": {
      "type": "int32",
      "example": 1234
    },
    "menu_id": {
      "type": "int32",
      "example": 1234
    },
    "name": {
      "type": "string",
      "example": "Sample"
    },
    "description": {
      "type": "string",
      "example": "string"
    },
    "price_cents": {
      "type": "int32",
      "example": 100
    },
    "is_available": {
      "type": "boolean",
      "example": true
    }
  }
}